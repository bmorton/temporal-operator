{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Temporal Server",
  "tags": ["temporal"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(service_requests, kubernetes_namespace)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Frontend request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(service_requests{operation=~\"StartWorkflowExecution|SignalWorkflowExecution\"}[5m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Persistence latency (p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(persistence_latency_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Shard ownership distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(sharditem_acquired) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Service errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(service_errors[5m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ]
    }
  ]
}
